# Normalize text files
* text=auto

# Source files
*.java text eol=lf
*.xml text eol=lf
*.fxml text eol=lf
*.md text eol=lf
*.gitignore text eol=lf
*.gitattributes text eol=lf

# Shell scripts
*.sh text eol=lf

# Windows scripts
*.cmd text eol=crlf
*.bat text eol=crlf

# Binary files
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary